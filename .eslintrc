{
  "root": true,
  "env": {
    "node": true,
    "browser": true,
    "es6": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "extends": [
    "eslint:recommended",
    "plugin:prettier/recommended"
  ],
  "plugins": [
    "prettier"
  ],
  "rules": {
    "prettier/prettier": "warn",
    "semi": ["warn", "always"],
    "indent": ["warn", 2],
    "no-console": "off",
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-undef": "warn",
    "no-with": "warn",
    "no-empty": ["warn", { "allowEmptyCatch": true }],
    "no-fallthrough": "warn",
    "no-prototype-builtins": "off",
    "object-curly-newline": ["warn", { "multiline": true, "consistent": true }],
    "comma-dangle": ["warn", "never"],
    "comma-spacing": ["warn", { "before": false, "after": true }],
    "comma-style": ["warn", "last"],
    "space-before-function-paren": ["warn", "never"],
    "space-in-parens": ["warn", "never"],
    "space-infix-ops": ["warn", { "int32Hint": true }],
    "keyword-spacing": ["warn", { "before": true, "after": true }],
    "key-spacing": ["warn", { "beforeColon": false, "afterColon": true }],
    "arrow-parens": ["warn", "always"],
    "prefer-const": "warn",
    "prefer-arrow-function": ["warn", { "allowNamedFunctions": true, "allowUnboundNestedFunctions": true }],
    "prefer-template": "warn",
    "template-curly-spacing": ["warn", "never"],
    "rest-spread-spacing": ["warn", "never"],
    "no-var": "warn",
    "prefer-rest-params": "warn",
    "prefer-spread": "warn",
    "no-useless-escape": "off",
    "no-useless-catch": "warn",
    "no-useless-rename": ["warn", { "ignoreImport": true, "ignoreExport": true }],
    "no-duplicate-imports": ["warn", { "include": ["node_modules"] }],
    "no-restricted-imports": "off",
    "no-restricted-syntax": ["warn", "WithStatement"],
    "no-lone-blocks": "warn",
    "no-else-return": ["warn", { "allowElseIf": true }],
    "no-unneeded-ternary": "warn",
    "no-mixed-operators": ["warn", { "allowSamePrecedence": true }],
    "no-implicit-boolean": "off",
    "no-bitwise": "off",
    "no-plusplus": ["warn", { "allowForLoopInit": true }],
    "no-void": ["warn", { "allowInFunctionArgs": true }],
    "no-alert": "warn",
    "no-eval": "warn",
    "no-unmodified-loop-condition": "warn",
    "no-constant-condition": ["warn", { "checkLoops": false }],
    "no-extra-boolean-cast": "warn",
    "no-extra-semi": "warn",
    "no-func-assign": "warn",
    "no-param-reassign": ["warn", { "props": true }],
    "no-floating-decimal": "warn",
    "no-octal": "warn",
    "no-octal-escape": "warn",
    "no-hex-escape": "warn",
    "no-new-wrappers": "warn",
    "no-new-func": "warn",
    "no-new-object": "warn",
    "no-new-symbol": "warn",
    "no-new-url": "warn",
    "no-new-native-nonconstructor": "warn",
    "no-path-concat": "warn",
    "no-process-exit": "off",
    "no-script-url": "warn",
    "no-self-assign": ["warn", { "props": true }],
    "no-self-comparison": "warn",
    "no-sequences": "warn",
    "no-throw-literal": "warn",
    "no-undef-init": "warn",
    "no-unexpected-multiline": "warn",
    "no-unused-labels": "warn",
    "no-use-before-define": ["warn", { "functions": true, "classes": true, "variables": true }],
    "no-useless-call": "warn",
    "no-useless-computed-key": "warn",
    "no-useless-concat": "warn",
    "no-useless-directive": "warn",
    "no-useless-escape": "warn",
    "no-useless-return": "warn",
    "no-var-requires": "off",
    "no-void": "warn",
    "no-warning-comments": ["warn", { "terms": ["todo", "fixme", "xxx"] }],
    "prefer-numeric-literals": "warn",
    "prefer-object-spread": "warn",
    "prefer-readonly-parameter-types": ["warn", { "allowInferredTypes": true }]
  }
}
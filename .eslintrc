{
  "root": true,
  "env": {
    "node": true,
    "browser": true,
    "es6": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "extends": [
    "eslint:recommended",
    "plugin:prettier/recommended"
  ],
  "plugins": [
    "prettier"
  ],
  "rules": {
    "prettier/prettier": "error",
    "semi": ["error", "always"],
    "indent": ["error", 2],
    "no-console": "off",
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
    "no-undef": "error",
    "no-with": "error",
    "no-empty": ["error", { "allowEmptyCatch": true }],
    "no-fallthrough": "error",
    "no-prototype-builtins": "off",
    "object-curly-newline": ["error", { "multiline": true, "consistent": true }],
    "comma-dangle": ["error", "never"],
    "comma-spacing": ["error", { "before": false, "after": true }],
    "comma-style": ["error", "last"],
    "space-before-function-paren": ["error", "never"],
    "space-in-parens": ["error", "never"],
    "space-infix-ops": ["error", { "int32Hint": true }],
    "keyword-spacing": ["error", { "before": true, "after": true }],
    "key-spacing": ["error", { "beforeColon": false, "afterColon": true }],
    "arrow-parens": ["error", "always"],
    "prefer-const": "error",
    "prefer-arrow-function": ["error", { "allowNamedFunctions": true, "allowUnboundNestedFunctions": true }],
    "prefer-template": "error",
    "template-curly-spacing": ["error", "never"],
    "rest-spread-spacing": ["error", "never"],
    "no-var": "error",
    "prefer-rest-params": "error",
    "prefer-spread": "error",
    "no-useless-escape": "off",
    "no-useless-catch": "error",
    "no-useless-rename": ["error", { "ignoreImport": true, "ignoreExport": true }],
    "no-duplicate-imports": ["error", { "include": ["node_modules"] }],
    "no-restricted-imports": "off",
    "no-restricted-syntax": ["error", "WithStatement"],
    "no-lone-blocks": "error",
    "no-else-return": ["error", { "allowElseIf": true }],
    "no-unneeded-ternary": "error",
    "no-mixed-operators": ["error", { "allowSamePrecedence": true }],
    "no-implicit-boolean": "off",
    "no-bitwise": "off",
    "no-plusplus": ["error", { "allowForLoopInit": true }],
    "no-with": "error",
    "no-void": ["error", { "allowInFunctionArgs": true }],
    "no-with": "error",
    "no-alert": "error",
    "no-eval": "error",
    "no-unmodified-loop-condition": "error",
    "no-constant-condition": ["error", { "checkLoops": false }],
    "no-extra-boolean-cast": "error",
    "no-extra-semi": "error",
    "no-func-assign": "error",
    "no-prototype-builtins": "off",
    "no-param-reassign": ["error", { "props": true }],
    "no-floating-decimal": "error",
    "no-octal": "error",
    "no-octal-escape": "error",
    "no-hex-escape": "error",
    "no-new-wrappers": "error",
    "no-new-func": "error",
    "no-new-object": "error",
    "no-new-symbol": "error",
    "no-new-url": "error",
    "no-new-native-nonconstructor": "error",
    "no-path-concat": "error",
    "no-process-exit": "off",
    "no-script-url": "error",
    "no-self-assign": ["error", { "props": true }],
    "no-self-comparison": "error",
    "no-sequences": "error",
    "no-throw-literal": "error",
    "no-undef-init": "error",
    "no-unexpected-multiline": "error",
    "no-unused-labels": "error",
    "no-unused-vars": ["error", { "vars": "all", "args": "none" }],
    "no-use-before-define": ["error", { "functions": true, "classes": true, "variables": true }],
    "no-useless-call": "error",
    "no-useless-computed-key": "error",
    "no-useless-concat": "error",
    "no-useless-directive": "error",
    "no-useless-escape": "error",
    "no-useless-return": "error",
    "no-var-requires": "off",
    "no-void": "error",
    "no-warning-comments": ["error", { "terms": ["todo", "fixme", "xxx"] }],
    "no-with": "error",
    "prefer-numeric-literals": "error",
    "prefer-object-spread": "error",
    "prefer-readonly-parameter-types": ["error", { "allowInferredTypes": true }],
    "prefer-readonly-types": ["error", { "allowInferredTypes": true }],
    "prefer-rest-params": "error",
    "prefer-spread": "error",
    "prefer-template": "error",
    "require-atomic-updates": "error",
    "require-await": "error",
    "require-yield": "error",
    "semi-spacing": ["error", { "before": false, "after": true }],
    "sort-imports": ["error", { "ignoreCase": true, "ignoreMemberSort": false, "allowSeparatedGroups": true }],
    "sort-keys": ["error", { "caseSensitive": true, "minProperties": 2 }],
    "sort-vars": ["error", { "ignoreCase": true }],
    "space-before-blocks": ["error", "always"],
    "space-before-function-paren": ["error", "never"],
    "space-in-parens": ["error", "never"],
    "space-infix-ops": ["error", { "int32Hint": true }],
    "strict": ["error", "never"],
    "switch-colon-spacing": ["error", { "before": false, "after": true }],
    "symbol-description": "error",
    "valid-typeof": ["error", { "requireStringLiterals": true }],
    "vars-on-top": ["error", { "variables": true, "functions": true }],
    "wrap-iife": ["error", "inside"],
    "wrap-regex": "error",
    "yield-star-spacing": ["error", { "before": true, "after": true }]
  },
  "overrides": [
    {
      "files": ["*.json"],
      "rules": {
        "prettier/prettier": ["error", { "printWidth": 120 }]
      }
    }
  ]
}
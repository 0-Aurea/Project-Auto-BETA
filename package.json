{
  "name": "nexus-proxy",
  "version": "1.0.0",
  "description": "A fully self-hosted web proxy",
  "main": "dist/server/index.js",
  "scripts": {
    "start": "node dist/server/index.js",
    "dev": "nodemon server/index.js",
    "build": "npm run lint && npm run test && npm run build:sw && npm run build:server",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:rewriting": "jest --testNamePattern=JSRewriting",
    "ci:lint": "eslint .",
    "ci:test": "jest",
    "ci:build": "npm run ci:lint && npm run ci:test && npm run build:sw && npm run build:server",
    "docker:build": "docker build -t nexus-proxy .",
    "docker:run": "docker run -p 8080:8080 nexus-proxy",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "build:sw": "babel frontend/sw -d frontend/dist/sw",
    "build:server": "babel server -d dist/server",
    "prettier": "prettier --write .",
    "ci": "npm run ci:build"
  },
  "keywords": [],
  "author": "NEXUS-AI",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.5.5",
    "body-parser": "^1.20.2",
    "brotli": "^0.1.2",
    "gzip-js": "^1.0.2",
    "jsdom": "^21.1.2",
    "uuid": "^9.0.0",
    "urlsafe-base64": "^2.0.0",
    "compression": "^1.7.1",
    "helmet": "^4.23.1",
    "http-proxy": "^1.20.1",
    "zstd": "^1.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.22.10",
    "@babel/preset-env": "^7.22.11",
    "babel-eslint": "^10.1.0",
    "eslint": "^8.57.0",
    "eslint-config-standard": "^7.0.0",
    "eslint-plugin-import": "^2.28.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-standard": "^5.3.1",
    "jest": "^29.5.0",
    "prettier": "^2.8.8",
    "nodemon": "^2.0.16"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NEXUS-AI/nexus-proxy.git"
  },
  "engines": {
    "node": ">=16.14.0"
  },
  "babel": {
    "presets": ["@babel/preset-env"]
  },
  "jest": {
    "moduleDirectories": ["node_modules", "server"],
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "coverageDirectory": "coverage"
  },
  "prettierConfig": ".prettierrc",
  "eslintConfig": {
    "extends": ["standard"]
  }
}
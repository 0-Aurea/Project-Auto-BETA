{
    "app": {
        "name": "AI Builder",
        "version": "1.0.0",
        "environment": "development",
        "debugMode": true,
        "port": 3000,
        "locale": "en_US",
        "logging": {
            "level": "info",
            "outputPath": "logs/app.log"
        },
        "apiKeys": {
            "someExternalService": "YOUR_EXTERNAL_SERVICE_API_KEY",
            "anotherService": "ANOTHER_SERVICE_KEY"
        }
    },
    "ai": {
        "defaultModel": "openai-gpt3.5-turbo",
        "apiKey": "YOUR_AI_SERVICE_API_KEY",
        "learningRate": 0.01,
        "cache": {
            "enabled": true,
            "durationSeconds": 3600
        },
        "rateLimiting": {
            "requestsPerMinute": 60,
            "burstLimit": 10
        },
        "models": {
            "openai-gpt3.5-turbo": {
                "endpoint": "https://api.openai.com/v1/chat/completions",
                "parameters": {
                    "model": "gpt-3.5-turbo",
                    "temperature": 0.7,
                    "max_tokens": 500,
                    "top_p": 1,
                    "frequency_penalty": 0,
                    "presence_penalty": 0
                }
            },
            "neural": {
                "endpoint": "http://localhost:8080/ai/neural-model",
                "parameters": {
                    "temperature": 0.5,
                    "max_tokens": 200,
                    "customParameter": "value"
                }
            },
            "anthropic-claude": {
                "endpoint": "https://api.anthropic.com/v1/messages",
                "parameters": {
                    "model": "claude-3-haiku-20240307",
                    "max_tokens": 1000,
                    "temperature": 0.8
                }
            }
        }
    }
}
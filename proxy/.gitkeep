import requests
import logging
from typing import List, Optional, Dict


class ProxyHandler:
    """Manages proxy configuration and rotation for HTTP requests.

    Attributes:
        proxies (List[str]): List of proxy URLs to rotate through.
        current_proxy (int): Index of the current proxy in the rotation.
        logger (logging.Logger): Configured logger for the class.
    """

    def __init__(self, proxies: List[str]):
        """Initialize ProxyHandler with a list of proxy URLs.

        Args:
            proxies: List of proxy URLs in the format 'http://user:pass@host:port'
        """
        self.proxies = self._validate_proxies(proxies)
        self.current_proxy = 0
        self.logger = logging.getLogger(__name__)
        if not self.proxies:
            raise ValueError("No valid proxies provided")

    def _validate_proxies(self, proxies: List[str]) -> List[str]:
        """Validate and filter working proxies from the provided list.

        Args:
            proxies: List of proxy URLs to validate

        Returns:
            List of validated working proxies
        """
        validated = []
        for proxy in proxies:
            if self.validate_proxy(proxy):
                validated.append(proxy)
        return validated

    def get_proxy(self) -> Optional[str]:
        """Get the next proxy in rotation.

        Returns:
            String containing the proxy URL or None if no proxies remain
        """
        if not self.proxies:
            return None

        proxy = self.proxies[self.current_proxy]
        self.current_proxy = (self.current_proxy + 1) % len(self.proxies)
        return proxy

    def validate_proxy(self, proxy: str) -> bool:
        """Test if a proxy is working by making a test request.

        Args:
            proxy: Proxy URL to test

        Returns:
            Boolean indicating if the proxy is valid
        """
        test_url = "http://httpbin.org/ip"
        proxy_dict = {"http": proxy, "https": proxy}
        
        try:
            response = requests.get(
                test_url,
                proxies=proxy_dict,
                timeout=10
            )
            if response.status_code == 200:
                self.logger.info(f"Proxy {proxy} is valid")
                return True
            self.logger.warning(f"Proxy {proxy} returned status code {response.status_code}")
            return False
        except requests.exceptions.RequestException as e:
            self.logger.error(f"Proxy {proxy} failed with error: {e}")
            return False

    def rotate_proxies(self) -> None:
        """Re-validate all proxies and remove non-working ones."""
        working_proxies = []
        for proxy in self.proxies:
            if self.validate_proxy(proxy):
                working_proxies.append(proxy)
        
        if not working_proxies:
            raise RuntimeError("All proxies are invalid")
            
        self.proxies = working_proxies
        self.current_proxy = 0
        self.logger.info(f"Rotated proxies - {len(working_proxies)} remaining")